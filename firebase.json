{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      ".git",
      ".github",
      "Ableton-tutorial"
    ],
    "rewrites": [
      {
        "source": "/__/auth/**",
        "destination": "/__/auth/index.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
