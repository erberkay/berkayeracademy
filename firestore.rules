rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Collection-group query için (members.html reply count sayımı)
    match /{path=**}/replies/{replyId} {
      allow read: if true;
    }

    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.uid == uid ||
        request.auth.token.email == "berkayer032@gmail.com"
      );
    }

    // Kullanıcının yanıt geçmişi (profil sayfası için)
    match /users/{uid}/userReplies/{replyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
    }

    match /testimonials/{id} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "berkayer032@gmail.com";
    }

    match /notifications/{uid}/items/{itemId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null;
    }

    match /announcements/{docId} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth != null && request.auth.token.email == "berkayer032@gmail.com";
    }

    match /forum/{postId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.token.email == "berkayer032@gmail.com" ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy','likeCount']) ||
        (request.auth.uid == resource.data.authorId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text','editedAt'])) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['solved','pinned','replyCount'])
      );
      allow delete: if request.auth != null && request.auth.token.email == "berkayer032@gmail.com";

      match /replies/{replyId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update: if request.auth != null && (
          request.auth.token.email == "berkayer032@gmail.com" ||
          (request.auth.uid == resource.data.authorId &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text','editedAt']))
        );
        allow delete: if request.auth != null && (
          request.auth.token.email == "berkayer032@gmail.com" ||
          request.auth.uid == resource.data.authorId
        );
      }
    }

    match /chats/{chatId} {
      allow read: if request.auth != null && (
        request.auth.uid in resource.data.participants ||
        request.auth.token.email == "berkayer032@gmail.com"
      );
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.participants &&
        request.resource.data.participants.size() == 2;
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.participants ||
        request.auth.token.email == "berkayer032@gmail.com"
      );
      allow delete: if request.auth != null &&
        request.auth.token.email == "berkayer032@gmail.com";

      match /messages/{msgId} {
        allow read: if request.auth != null && (
          request.auth.token.email == "berkayer032@gmail.com" ||
          chatId.matches('.*' + request.auth.uid + '.*')
        );
        allow create: if request.auth != null &&
          request.auth.uid == request.resource.data.fromUid &&
          chatId.matches('.*' + request.auth.uid + '.*');
        allow delete: if request.auth != null &&
          request.auth.token.email == "berkayer032@gmail.com";
      }
    }

    match /follows/{followId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.followerId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.followerId;
    }

    match /userSettings/{uid} {
      allow read, write: if request.auth != null && (
        request.auth.uid == uid ||
        request.auth.token.email == "berkayer032@gmail.com"
      );
    }

    // ── Booking system ──
    match /access_codes/{codeId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email == "berkayer032@gmail.com";
    }

    match /reservations/{uid} {
      allow read: if request.auth != null && (
        request.auth.uid == uid ||
        request.auth.token.email == "berkayer032@gmail.com"
      );
      allow create: if request.auth != null && (
        request.auth.uid == uid ||
        request.auth.token.email == "berkayer032@gmail.com"
      );
      allow update: if request.auth != null && (
        request.auth.uid == uid ||
        request.auth.token.email == "berkayer032@gmail.com"
      );
      allow delete: if request.auth != null &&
        request.auth.token.email == "berkayer032@gmail.com";
    }

    match /booked_slots/{slotId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /lesson_requests/{reqId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.from_uid ||
        request.auth.token.email == "berkayer032@gmail.com"
      );
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.token.email == "berkayer032@gmail.com";
    }

  }
}
