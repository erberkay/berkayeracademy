rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Collection-group query için (members.html reply count sayımı)
    match /{path=**}/replies/{replyId} {
      allow read: if true;
    }

    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.uid == uid ||
        request.auth.token.email == "berkayer032@gmail.com"
      );
    }

    match /users/{uid}/userReplies/{replyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
    }

    match /users/{uid}/beats/{beatId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /users/{uid}/presets/{presetId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /testimonials/{id} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.token.email == "berkayer032@gmail.com";
    }

    match /notifications/{uid}/items/{itemId} {
      allow read, delete: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create: if request.auth != null && request.resource.data.fromUid == request.auth.uid;
    }

    match /announcements/{docId} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth != null && request.auth.token.email == "berkayer032@gmail.com";
    }

    match /forum/{postId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.token.email == "berkayer032@gmail.com" ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy','likeCount']) ||
        (request.auth.uid == resource.data.authorId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text','editedAt'])) ||
        (request.auth.uid == resource.data.authorId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['solved'])) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['replyCount'])
      );
      allow delete: if request.auth != null && request.auth.token.email == "berkayer032@gmail.com";

      match /replies/{replyId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update: if request.auth != null && (
          request.auth.token.email == "berkayer032@gmail.com" ||
          (request.auth.uid == resource.data.authorId &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text','editedAt']))
        );
        allow delete: if request.auth != null && (
          request.auth.token.email == "berkayer032@gmail.com" ||
          request.auth.uid == resource.data.authorId
        );
      }
    }

    match /chats/{chatId} {
      allow read: if request.auth != null && (
        request.auth.uid in resource.data.participants ||
        request.auth.token.email == "berkayer032@gmail.com"
      );
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.participants &&
        request.resource.data.participants.size() == 2;
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.participants ||
        request.auth.token.email == "berkayer032@gmail.com"
      );
      allow delete: if request.auth != null &&
        request.auth.token.email == "berkayer032@gmail.com";

      match /messages/{msgId} {
        allow read: if request.auth != null && (
          request.auth.token.email == "berkayer032@gmail.com" ||
          chatId.matches('.*' + request.auth.uid + '.*')
        );
        allow create: if request.auth != null &&
          request.auth.uid == request.resource.data.fromUid &&
          chatId.matches('.*' + request.auth.uid + '.*');
        allow update: if request.auth != null &&
          chatId.matches('.*' + request.auth.uid + '.*') &&
          resource.data.type == 'collab_request' &&
          request.auth.uid != resource.data.fromUid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
        allow delete: if request.auth != null &&
          request.auth.token.email == "berkayer032@gmail.com";
      }
    }

    match /follows/{followId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.followerId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.followerId;
    }

    match /userSettings/{uid} {
      allow read, write: if request.auth != null && (
        request.auth.uid == uid ||
        request.auth.token.email == "berkayer032@gmail.com"
      );
    }

    // ── Booking system ──
    match /access_codes/{codeId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email == "berkayer032@gmail.com";
    }

    match /reservations/{uid} {
      allow read: if request.auth != null && (
        request.auth.uid == uid ||
        request.auth.token.email == "berkayer032@gmail.com"
      );
      allow create, delete: if request.auth != null &&
        request.auth.token.email == "berkayer032@gmail.com";
      allow update: if request.auth != null && (
        request.auth.token.email == "berkayer032@gmail.com" ||
        (request.auth.uid == uid && (
          // Note-only update
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['note']) ||
          // Payment request
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['payment_pending']) &&
            request.resource.data.payment_pending == true) ||
          // Rules acceptance (write-once: must not already be set)
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rules_accepted_at']) &&
            !('rules_accepted_at' in resource.data))
          // Lessons: sadece admin güncelleyebilir
        ))
      );
    }

    match /booked_slots/{slotId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        request.auth.token.email == "berkayer032@gmail.com";
      allow create: if request.auth != null &&
        request.resource.data.student_uid == request.auth.uid &&
        request.auth.token.email != "berkayer032@gmail.com";
      allow delete: if request.auth != null &&
        resource.data.student_uid == request.auth.uid &&
        request.auth.token.email != "berkayer032@gmail.com";
    }

    match /lesson_requests/{reqId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.from_uid ||
        request.auth.token.email == "berkayer032@gmail.com"
      );
      allow create: if request.auth != null &&
        request.resource.data.from_uid == request.auth.uid;
      allow update: if request.auth != null && request.auth.token.email == "berkayer032@gmail.com";
      allow delete: if request.auth != null && (
        (request.auth.uid == resource.data.from_uid && resource.data.status == 'rejected') ||
        request.auth.token.email == "berkayer032@gmail.com"
      );
    }

    match /settings/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email == "berkayer032@gmail.com";
    }

    match /booking_access_requests/{uid} {
      allow read: if request.auth != null && (
        request.auth.uid == uid ||
        request.auth.token.email == "berkayer032@gmail.com"
      );
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update, delete: if request.auth != null && (
        request.auth.uid == uid ||
        request.auth.token.email == "berkayer032@gmail.com"
      );
    }

    // UUID key ile güvende — app auth olmadan okur, write için auth gerekli
    match /app_bridge/{key} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /lesson_questions/{qId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.uid ||
        request.auth.token.email == "berkayer032@gmail.com"
      );
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
      allow update: if request.auth != null && request.auth.token.email == "berkayer032@gmail.com";
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.uid ||
        request.auth.token.email == "berkayer032@gmail.com"
      );

      match /answers/{aId} {
        allow read: if request.auth != null && (
          request.auth.token.email == "berkayer032@gmail.com" ||
          request.auth.uid == get(/databases/$(database)/documents/lesson_questions/$(qId)).data.uid
        );
        allow create: if request.auth != null && (
          request.auth.token.email == "berkayer032@gmail.com" ||
          request.resource.data.fromAdmin == false
        );
      }
    }

  }
}
