rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Collection-group query için (members.html reply count sayımı)
    match /{path=**}/replies/{replyId} {
      allow read: if true;
    }

    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.uid == uid ||
        request.auth.token.email == "berkayer032@gmail.com"
      );
    }

    // Kullanıcının yanıt geçmişi (profil sayfası için)
    match /users/{uid}/userReplies/{replyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
    }

    // site_1.html — beat ve preset kayıtları
    match /users/{uid}/beats/{beatId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /users/{uid}/presets/{presetId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /testimonials/{id} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.token.email == "berkayer032@gmail.com";
    }

    match /notifications/{uid}/items/{itemId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == uid;
      // fromUid zorunlu — sahte gönderici adıyla bildirim oluşturulamaz
      allow create: if request.auth != null && request.resource.data.fromUid == request.auth.uid;
    }

    match /announcements/{docId} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth != null && request.auth.token.email == "berkayer032@gmail.com";
    }

    match /forum/{postId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.token.email == "berkayer032@gmail.com" ||
        // Beğeni: herhangi bir üye
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy','likeCount']) ||
        // Yazarın kendi konusunu düzenlemesi
        (request.auth.uid == resource.data.authorId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text','editedAt'])) ||
        // Çözüldü işareti: sadece konu sahibi veya admin
        (request.auth.uid == resource.data.authorId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['solved'])) ||
        // Yanıt sayısı: herhangi bir üye (yanıt eklenince/silinince güncellenir)
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['replyCount'])
      );
      allow delete: if request.auth != null && request.auth.token.email == "berkayer032@gmail.com";

      match /replies/{replyId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update: if request.auth != null && (
          request.auth.token.email == "berkayer032@gmail.com" ||
          (request.auth.uid == resource.data.authorId &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text','editedAt']))
        );
        allow delete: if request.auth != null && (
          request.auth.token.email == "berkayer032@gmail.com" ||
          request.auth.uid == resource.data.authorId
        );
      }
    }

    match /chats/{chatId} {
      allow read: if request.auth != null && (
        request.auth.uid in resource.data.participants ||
        request.auth.token.email == "berkayer032@gmail.com"
      );
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.participants &&
        request.resource.data.participants.size() == 2;
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.participants ||
        request.auth.token.email == "berkayer032@gmail.com"
      );
      allow delete: if request.auth != null &&
        request.auth.token.email == "berkayer032@gmail.com";

      match /messages/{msgId} {
        allow read: if request.auth != null && (
          request.auth.token.email == "berkayer032@gmail.com" ||
          chatId.matches('.*' + request.auth.uid + '.*')
        );
        allow create: if request.auth != null &&
          request.auth.uid == request.resource.data.fromUid &&
          chatId.matches('.*' + request.auth.uid + '.*');
        allow delete: if request.auth != null &&
          request.auth.token.email == "berkayer032@gmail.com";
      }
    }

    match /follows/{followId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.followerId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.followerId;
    }

    match /userSettings/{uid} {
      allow read, write: if request.auth != null && (
        request.auth.uid == uid ||
        request.auth.token.email == "berkayer032@gmail.com"
      );
    }

    // ── Booking system ──
    match /access_codes/{codeId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email == "berkayer032@gmail.com";
    }

    match /reservations/{uid} {
      allow read: if request.auth != null && (
        request.auth.uid == uid ||
        request.auth.token.email == "berkayer032@gmail.com"
      );
      // Only admin can create or delete reservations
      allow create, delete: if request.auth != null &&
        request.auth.token.email == "berkayer032@gmail.com";
      // Admin can update anything; student can update note, payment_pending, lessons, reschedule_credits
      allow update: if request.auth != null && (
        request.auth.token.email == "berkayer032@gmail.com" ||
        (request.auth.uid == uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['note', 'payment_pending', 'lessons', 'reschedule_credits']))
      );
    }

    match /booked_slots/{slotId} {
      allow read: if request.auth != null;
      // Admin can write anything
      allow write: if request.auth != null &&
        request.auth.token.email == "berkayer032@gmail.com";
      // Students can create/delete only their own slots (for reschedule)
      allow create: if request.auth != null &&
        request.resource.data.student_uid == request.auth.uid &&
        request.auth.token.email != "berkayer032@gmail.com";
      allow delete: if request.auth != null &&
        resource.data.student_uid == request.auth.uid &&
        request.auth.token.email != "berkayer032@gmail.com";
    }

    match /lesson_requests/{reqId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.from_uid ||
        request.auth.token.email == "berkayer032@gmail.com"
      );
      // Student can only create requests on their own behalf
      allow create: if request.auth != null &&
        request.resource.data.from_uid == request.auth.uid;
      allow update: if request.auth != null && request.auth.token.email == "berkayer032@gmail.com";
    }

    match /settings/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email == "berkayer032@gmail.com";
    }

    match /booking_access_requests/{uid} {
      allow read: if request.auth != null && (
        request.auth.uid == uid ||
        request.auth.token.email == "berkayer032@gmail.com"
      );
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update, delete: if request.auth != null && (
        request.auth.uid == uid ||
        request.auth.token.email == "berkayer032@gmail.com"
      );
    }

    match /lesson_questions/{qId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.uid ||
        request.auth.token.email == "berkayer032@gmail.com"
      );
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
      allow update: if request.auth != null && request.auth.token.email == "berkayer032@gmail.com";
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.uid ||
        request.auth.token.email == "berkayer032@gmail.com"
      );

      match /answers/{aId} {
        allow read: if request.auth != null;
        // Admin can write anything; students can only create with fromAdmin == false
        allow create: if request.auth != null && (
          request.auth.token.email == "berkayer032@gmail.com" ||
          request.resource.data.fromAdmin == false
        );
      }
    }

  }
}
