rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /{path=**}/replies/{replyId} {
      allow read: if true;
    }

    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.uid == uid ||
        request.auth.token.email == "berkayer032@gmail.com"
      );
    }

    match /testimonials/{id} {
      allow read: if true;
      allow write: if request.auth.token.email == "berkayer032@gmail.com";
    }

    match /notifications/{uid}/items/{itemId} {
      allow read, delete: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null;
    }

    match /announcements/{docId} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth != null && request.auth.token.email == "berkayer032@gmail.com";
    }

    match /forum/{postId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.token.email == "berkayer032@gmail.com" ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy','likeCount']) ||
        (request.auth.uid == resource.data.authorId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text','editedAt'])) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['solved','pinned','replyCount'])
      );
      allow delete: if request.auth.token.email == "berkayer032@gmail.com";

      match /replies/{replyId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update: if request.auth != null && (
          request.auth.token.email == "berkayer032@gmail.com" ||
          (request.auth.uid == resource.data.authorId &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text','editedAt']))
        );
        allow delete: if request.auth != null && (
          request.auth.token.email == "berkayer032@gmail.com" ||
          request.auth.uid == resource.data.authorId
        );
      }
    }

    match /chats/{chatId} {
      allow read: if request.auth != null && (
        request.auth.uid in resource.data.participants ||
        request.auth.token.email == "berkayer032@gmail.com"
      );
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.participants &&
        request.resource.data.participants.size() == 2;
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.participants ||
        request.auth.token.email == "berkayer032@gmail.com"
      );

      match /messages/{msgId} {
        allow read: if request.auth != null && (
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants ||
          request.auth.token.email == "berkayer032@gmail.com"
        );
        allow create: if request.auth != null &&
          request.auth.uid == request.resource.data.fromUid &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    match /userSettings/{uid} {
      allow read, write: if request.auth != null && (
        request.auth.uid == uid ||
        request.auth.token.email == "berkayer032@gmail.com"
      );
    }

  }
}
